{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sounddecisions.local/schema/axis-spec-v2.json",
  "title": "SoundDecisions Axis Specification v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_id",
    "version",
    "status",
    "freeze",
    "scope",
    "shared_contract",
    "axes"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "spec_id": {"const": "sounddecisions_axis_spec_v2"},
    "version": {"type": "string"},
    "status": {"const": "DRAFT_AWAITING_DUAL_PI_SIGNATURE"},
    "freeze": {
      "type": "object",
      "required": [
        "authority",
        "envelope_schema",
        "expected_envelope_path",
        "envelope_present",
        "measurement_authorized",
        "quarantine_release_authorized",
        "content_hash_rule",
        "rule"
      ],
      "properties": {
        "authority": {"const": "separate_signed_envelope"},
        "envelope_schema": {"const": "./axis_spec_v2.freeze.schema.json"},
        "expected_envelope_path": {"const": "./axis_spec_v2.freeze.json"},
        "envelope_present": {"const": false},
        "measurement_authorized": {"const": false},
        "quarantine_release_authorized": {"const": false},
        "content_hash_rule": {"type": "string", "minLength": 1},
        "rule": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "scientific_unit",
        "clip_is_only_a_container",
        "axes",
        "causal_analysis_in_scope",
        "confirmatory_execution_in_scope"
      ]
    },
    "shared_contract": {
      "type": "object",
      "required": [
        "anchor",
        "missingness",
        "readout_targets",
        "categorical_commitment",
        "window_rule",
        "threshold_and_model_selection",
        "semantic_calibration",
        "allowed_workstream_statuses"
      ]
    },
    "axes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["presence", "timing", "class", "material", "binding"],
      "properties": {
        "presence": {"$ref": "#/$defs/axis"},
        "timing": {"$ref": "#/$defs/axis"},
        "class": {"$ref": "#/$defs/axis"},
        "material": {"$ref": "#/$defs/axis"},
        "binding": {"$ref": "#/$defs/axis"}
      }
    }
  },
  "$defs": {
    "axis": {
      "type": "object",
      "required": [
        "scientific_meaning",
        "unit_of_analysis",
        "anchor_required",
        "prerequisites",
        "target_type",
        "selection_procedure",
        "missingness",
        "reference_and_negative",
        "null_and_baseline",
        "commitment_statistic",
        "external_readout",
        "internal_readout",
        "robustness_tests",
        "semantic_calibration",
        "minimum_persisted_fields",
        "disposition_rules"
      ],
      "properties": {
        "scientific_meaning": {"type": "string", "minLength": 1},
        "unit_of_analysis": {"type": "string", "minLength": 1},
        "anchor_required": {"type": "boolean"},
        "prerequisites": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "target_type": {"type": "object"},
        "selection_procedure": {"type": "string", "minLength": 1},
        "missingness": {"type": "string", "minLength": 1},
        "reference_and_negative": {"type": "object"},
        "null_and_baseline": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "commitment_statistic": {"type": "string", "minLength": 1},
        "external_readout": {"$ref": "#/$defs/readout"},
        "internal_readout": {"$ref": "#/$defs/readout"},
        "robustness_tests": {"type": "array", "minItems": 2, "items": {"type": "string"}},
        "semantic_calibration": {"type": "string", "minLength": 1},
        "minimum_persisted_fields": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "disposition_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "PASS",
            "UNRESOLVED",
            "INVALID_MEASUREMENT",
            "INCOMPLETE_ARTIFACTS",
            "ENGINEERING_FAILURE",
            "redesign_or_demotion"
          ],
          "properties": {
            "PASS": {"type": "string", "minLength": 1},
            "UNRESOLVED": {"type": "string", "minLength": 1},
            "INVALID_MEASUREMENT": {"type": "string", "minLength": 1},
            "INCOMPLETE_ARTIFACTS": {"type": "string", "minLength": 1},
            "ENGINEERING_FAILURE": {"type": "string", "minLength": 1},
            "redesign_or_demotion": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "readout": {
      "type": "object",
      "required": ["target", "metrics"],
      "properties": {
        "target": {"type": "string", "minLength": 1},
        "metrics": {"type": "array", "minItems": 2, "items": {"type": "string"}}
      }
    }
  }
}
